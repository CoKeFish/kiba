{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiba Installer",
  "version": "0.1.1",
  "identifier": "xyz.kiba.installer",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kiba Installer",
        "width": 640,
        "height": 540,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "minWidth": 640,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Install Kiba MCP",
    "longDescription": "One-click installer that adds the Kiba MCP server to Claude Desktop, Cursor, and Claude Code."
  },
  "plugins": {}
}
