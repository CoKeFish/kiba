{
  "name": "@kiba/demo-agents",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:yield\" \"npm:dev:risk\" \"npm:dev:translator\" \"npm:dev:price\" \"npm:dev:code\" \"npm:dev:firecrawl\" \"npm:dev:world\" \"npm:dev:randomizer\"",
    "dev:yield": "tsx watch src/yield-hunter.ts",
    "dev:risk": "tsx watch src/risk-auditor.ts",
    "dev:translator": "tsx watch src/translator.ts",
    "dev:price": "tsx watch src/price-oracle.ts",
    "dev:code": "tsx watch src/code-reviewer.ts",
    "dev:firecrawl": "tsx watch src/firecrawl.ts",
    "dev:world": "tsx watch src/world-clock.ts",
    "dev:randomizer": "tsx watch src/randomizer.ts",
    "start:yield": "tsx src/yield-hunter.ts",
    "start:risk": "tsx src/risk-auditor.ts",
    "start:translator": "tsx src/translator.ts",
    "start:price": "tsx src/price-oracle.ts",
    "start:code": "tsx src/code-reviewer.ts",
    "start:firecrawl": "tsx src/firecrawl.ts",
    "start:world": "tsx src/world-clock.ts",
    "start:randomizer": "tsx src/randomizer.ts",
    "build": "tsc",
    "test": "node --import tsx --test --test-reporter=spec test/firecrawl.test.ts"
  },
  "dependencies": {
    "@kiba/sdk": "*",
    "express": "^4.19.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
