#!/bin/bash
# Kiba CLI helper
# Usage: kiba <command> [args]

set -e

CMD=$1
shift || true

WORKDIR=/workspace
LIB_RS=$WORKDIR/programs/kiba/src/lib.rs
ANCHOR_TOML=$WORKDIR/Anchor.toml

case $CMD in
  status)
    echo "═════════ Kiba Status ═════════"
    solana config get
    echo ""
    if WALLET=$(solana address 2>/dev/null); then
      echo "Wallet:  $WALLET"
      echo "Balance: $(solana balance 2>/dev/null)"
    else
      echo "Wallet:  ⚠ no wallet — corre 'kiba init-wallet'"
    fi
    echo "Program ID env: ${PROGRAM_ID:-(not set)}"
    if [ -f $WORKDIR/target/deploy/kiba-keypair.json ]; then
      echo "Program keypair address: $(solana address -k $WORKDIR/target/deploy/kiba-keypair.json)"
    fi
    echo "═══════════════════════════════════════"
    ;;

  init-wallet)
    if [ -f /root/.config/solana/id.json ]; then
      echo "✓ Wallet ya existe en /root/.config/solana/id.json"
      solana address
    else
      solana-keygen new --no-bip39-passphrase
    fi
    ;;

  airdrop)
    AMOUNT=${1:-2}
    echo "Pidiendo $AMOUNT SOL..."
    solana airdrop "$AMOUNT"
    solana balance
    ;;

  build)
    cd $WORKDIR
    anchor build
    ;;

  deploy)
    cd $WORKDIR

    # Asegurar wallet
    if [ ! -f /root/.config/solana/id.json ]; then
      echo "→ creando wallet..."
      solana-keygen new --no-bip39-passphrase
    fi

    # Asegurar balance
    BAL=$(solana balance | grep -oE '[0-9.]+' | head -1)
    if [ -z "$BAL" ] || [ "$(echo "$BAL < 2" | awk '{print ($1<2)}')" = "1" ]; then
      echo "→ pidiendo airdrop..."
      solana airdrop 2 || true
    fi

    # Primer build genera el keypair del programa
    if [ ! -f target/deploy/kiba-keypair.json ]; then
      echo "→ build inicial (genera keypair del programa)..."
      anchor build
    fi

    PID=$(solana address -k target/deploy/kiba-keypair.json)
    echo "→ Program ID: $PID"

    # Sincronizar declare_id! y Anchor.toml
    sed -i.bak "s/declare_id!(\"[^\"]*\")/declare_id!(\"$PID\")/" $LIB_RS
    sed -i.bak "s|kiba = \"[^\"]*\"|kiba = \"$PID\"|g" $ANCHOR_TOML
    rm -f $LIB_RS.bak $ANCHOR_TOML.bak

    echo "→ rebuild con declare_id! correcto..."
    anchor build

    echo "→ deploying a devnet..."
    anchor deploy --provider.cluster devnet

    echo ""
    echo "═══════════════════════════════════════════"
    echo "  ✓ Deployed: $PID"
    echo "═══════════════════════════════════════════"
    echo ""
    echo "Próximos pasos:"
    echo "  1. exit (salir del container)"
    echo "  2. Editar .env y poner:    PROGRAM_ID=$PID"
    echo "  3. docker compose restart backend demo-agents orchestrator-agent"
    ;;

  localnet-up)
    # Inicia solana-test-validator-2.3 en background si no está corriendo
    if pgrep -x "solana-test-valid" > /dev/null 2>&1; then
      echo "✓ solana-test-validator ya está corriendo"
    else
      echo "→ iniciando solana-test-validator-2.3 en background..."
      solana-test-validator-2.3 \
        --ledger /tmp/test-ledger \
        --reset \
        --rpc-port 8899 \
        --bind-address 0.0.0.0 \
        --log /tmp/validator.log \
        > /dev/null 2>&1 &
      echo "→ esperando que el validator arranque..."
      for i in $(seq 1 30); do
        if curl -sf http://localhost:8899/health > /dev/null 2>&1; then
          echo "✓ Validator listo en :8899"
          break
        fi
        sleep 1
        if [ "$i" = "30" ]; then
          echo "✗ Validator no arrancó en 30s — revisa /tmp/validator.log"
          exit 1
        fi
      done
    fi
    solana config set --url http://localhost:8899
    echo "✓ Solana CLI apunta a localnet"
    ;;

  localnet-deploy)
    cd $WORKDIR

    # Asegurar que el validator está corriendo
    if ! curl -sf http://localhost:8899/health > /dev/null 2>&1; then
      echo "→ validator no está corriendo, iniciando..."
      kiba localnet-up
    fi

    # Asegurar wallet
    if [ ! -f /root/.config/solana/id.json ]; then
      solana-keygen new --no-bip39-passphrase
    fi

    # Configurar CLI para localnet
    solana config set --url http://localhost:8899

    # Airdrop en localnet (ilimitado, no cuesta nada)
    echo "→ airdrop en localnet..."
    solana airdrop 10 || true

    # Primer build
    if [ ! -f target/deploy/kiba-keypair.json ]; then
      echo "→ build inicial..."
      anchor build
    fi

    PID=$(solana address -k target/deploy/kiba-keypair.json)
    echo "→ Program ID: $PID"

    # Sincronizar declare_id! y Anchor.toml
    sed -i.bak "s/declare_id!(\"[^\"]*\")/declare_id!(\"$PID\")/" $LIB_RS
    sed -i.bak "s|kiba = \"[^\"]*\"|kiba = \"$PID\"|g" $ANCHOR_TOML
    rm -f $LIB_RS.bak $ANCHOR_TOML.bak

    echo "→ rebuild con declare_id! correcto..."
    anchor build

    echo "→ deploying a localnet..."
    anchor deploy --provider.cluster localnet

    echo ""
    echo "═══════════════════════════════════════════"
    echo "  ✓ Deployed en localnet: $PID"
    echo "═══════════════════════════════════════════"
    echo ""
    echo "Próximos pasos:"
    echo "  1. Editar .env (en el host) y poner:"
    echo "     SOLANA_RPC_URL=http://contracts:8899"
    echo "     PROGRAM_ID=$PID"
    echo "  2. docker compose restart backend demo-agents orchestrator-agent gateway"
    ;;

  test)
    cd $WORKDIR
    anchor test --skip-local-validator
    ;;

  logs)
    if [ -z "$1" ]; then
      echo "Streaming logs de devnet (Ctrl+C para parar)..."
      solana logs
    else
      echo "Logs de transacción $1:"
      solana confirm "$1" -v
    fi
    ;;

  network)
    NET=${1:-devnet}
    case $NET in
      devnet) URL=https://api.devnet.solana.com ;;
      mainnet) URL=https://api.mainnet-beta.solana.com ;;
      localnet) URL=http://localhost:8899 ;;
      *) URL=$NET ;;
    esac
    solana config set --url "$URL"
    ;;

  list-agents)
    if [ -z "$PROGRAM_ID" ]; then
      echo "PROGRAM_ID no configurado en env"
      exit 1
    fi
    echo "Querying registry on-chain..."
    curl -s -X POST "$(solana config get | grep 'RPC URL' | awk '{print $3}')" \
      -H "Content-Type: application/json" \
      -d "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getProgramAccounts\",\"params\":[\"$PROGRAM_ID\",{\"encoding\":\"base64\"}]}" \
      | jq -C '.result | length as $n | "\($n) program accounts found"'
    ;;

  help|"")
    cat <<EOF
Kiba CLI

Usage: kiba <command> [args]

Commands:
  status                Estado actual: red, wallet, balance, program ID
  init-wallet           Crear wallet nueva (si no existe)
  airdrop [amount]      Pedir SOL de devnet (default: 2) — máx 10 SOL/8h
  build                 anchor build
  deploy                Deploy a devnet (usa SOL real de devnet)
  localnet-up           Inicia solana-test-validator-2.3 en background (:8899)
  localnet-deploy       Deploy a localnet (SOL ilimitado, sin coste)
  test                  Corre tests del programa
  logs [signature]      Stream logs en vivo o detalles de una tx específica
  network <name>        Cambia red: devnet | mainnet | localnet
  list-agents           Lista accounts del programa on-chain
  help                  Esta ayuda

Flujo desarrollo (localnet — recomendado):
  kiba localnet-up
  kiba localnet-deploy
  # → editar .env: SOLANA_RPC_URL=http://contracts:8899  PROGRAM_ID=<nuevo>
  # → docker compose restart backend demo-agents orchestrator-agent gateway

Flujo deploy final a devnet (solo cuando esté listo):
  kiba init-wallet
  kiba airdrop 5
  kiba deploy
  # → copiar Program ID al .env, reiniciar containers
EOF
    ;;

  *)
    echo "Comando desconocido: $CMD"
    echo "Corre: kiba help"
    exit 1
    ;;
esac
