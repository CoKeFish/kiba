    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test --test-reporter=spec test/auth.test.ts test/tools.test.ts",
    "prepare": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ]
}
