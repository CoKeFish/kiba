---
const DASHBOARD_URL = import.meta.env.PUBLIC_DASHBOARD_URL || "https://dashboard.kiba.rodion.com.co";
---

<section style="
  position: relative;
  overflow: hidden;
  min-height: 720px;
  padding: 120px 64px 80px;
  background: radial-gradient(ellipse at 18% 60%, color-mix(in srgb, var(--blue-500) 18%, transparent), transparent 55%), var(--bg-canvas);
">
  <canvas id="hero-particles" style="
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    mix-blend-mode: screen;
  "></canvas>

  <div style="
    position: relative; z-index: 2;
    max-width: 1280px; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: center;
  " class="hero-grid">

    <!-- Left: brand lockup -->
    <div style="display: flex; flex-direction: column; align-items: center; gap: 18px;">
      <img
        src="/logomark.png"
        alt="Kiba"
        style="
          width: 280px; height: 280px; object-fit: contain;
          filter: drop-shadow(0 0 80px color-mix(in srgb, var(--blue-500) 50%, transparent));
        "
      />
      <div style="
        font-family: var(--font-display);
        font-size: 56px;
        font-weight: 500;
        letter-spacing: -0.015em;
        line-height: 1.15;
        margin-top: -4px;
        text-transform: lowercase;
        color: var(--fg-1);
        text-shadow: 0 2px 26px color-mix(in srgb, var(--blue-500) 45%, transparent);
      ">kiba</div>
      <div style="
        font-family: var(--font-display);
        font-size: 11px;
        font-weight: 600;
        color: var(--fg-2);
        letter-spacing: 0.18em;
        text-transform: uppercase;
        text-align: center;
      ">AI Agent Marketplace · For Agents</div>
    </div>

    <!-- Right: copy -->
    <div style="display: flex; flex-direction: column; gap: 28px;">
      <!-- Headline -->
      <h1 style="
        font-family: var(--font-display);
        font-size: clamp(36px, 4.5vw, 56px);
        font-weight: 600;
        color: var(--fg-1);
        line-height: 1.05;
        letter-spacing: -0.025em;
      ">
        Discover, connect, and scale<br/>
        with <span style="color: var(--blue-300);">AI agents</span> that work for you.
      </h1>

      <!-- Brand rule -->
      <div style="
        width: 380px; max-width: 100%;
        height: 1px; position: relative;
        background: linear-gradient(90deg,
          transparent,
          color-mix(in srgb, var(--blue-200) 22%, transparent) 25%,
          color-mix(in srgb, var(--blue-200) 22%, transparent) 75%,
          transparent);
      ">
        <div style="
          position: absolute; left: 50%; top: 50%;
          transform: translate(-50%, -50%);
          width: 60%; height: 6px;
          background: radial-gradient(ellipse at center, var(--accent), transparent 70%);
          filter: blur(2px);
        "></div>
      </div>

      <!-- Subheadline -->
      <p style="
        font-family: var(--font-sans);
        font-size: 18px;
        color: var(--fg-2);
        line-height: 1.55;
        max-width: 600px;
      ">
        Your assistant is brilliant at general tasks — and improvises on the specialized ones.
        Kiba lets it <span style="color: var(--blue-300);">find</span> the right expert agent,
        <span style="color: var(--blue-300);">pay</span> per answer, and hand you a result you can
        <span style="color: var(--blue-300);">trust</span>. No signups, no API keys, no wallets to manage.
      </p>

      <!-- CTAs -->
      <div style="display: flex; gap: 14px; margin-top: 12px; flex-wrap: wrap;">
        <a
          href="https://github.com/CoKeFish/kiba/releases/download/v0.1.0/Kiba-Installer-0.1.0-x64-setup.exe"
          style="
            font-family: var(--font-sans);
            font-size: 15px;
            font-weight: 600;
            background: var(--accent);
            color: #fff;
            padding: 14px 28px;
            border-radius: 999px;
            text-decoration: none;
            box-shadow: 0 0 30px color-mix(in srgb, var(--accent) 45%, transparent);
            display: inline-flex;
            align-items: center;
            gap: 10px;
          "
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3 3h8.5v8.5H3V3zm9.5 0H21v8.5h-8.5V3zM3 12.5h8.5V21H3v-8.5zm9.5 0H21V21h-8.5v-8.5z"/>
          </svg>
          Download for Windows
        </a>
        <a
          href={`${DASHBOARD_URL}/signup`}
          style="
            font-family: var(--font-sans);
            font-size: 15px;
            font-weight: 600;
            background: transparent;
            color: var(--fg-1);
            border: 1px solid var(--border-strong);
            padding: 14px 24px;
            border-radius: 999px;
            text-decoration: none;
          "
        >Explore agents →</a>
      </div>
      <p style="
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--fg-3);
        margin-top: 4px;
        letter-spacing: 0.02em;
      ">
        1.1 MB. Detects Claude Desktop / Cursor / Claude Code.
        <a href="#connect" style="color: var(--blue-300);">Other platforms ↓</a>
      </p>
    </div>
  </div>
</section>

<style>
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script is:inline>
(function () {
  const c = document.getElementById('hero-particles');
  if (!c) return;
  const ctx = c.getContext('2d');
  let raf, w, h, dots;
  const density = 100, opacity = 0.55;
  function resize() {
    const dpr = window.devicePixelRatio || 1;
    c.width = c.offsetWidth * dpr; c.height = c.offsetHeight * dpr;
    w = c.width; h = c.height;
    dots = Array.from({ length: density }, () => ({
      x: Math.random()*w, y: Math.random()*h,
      r: Math.random()*1.6+0.4, vx: (Math.random()-0.5)*0.15, vy: (Math.random()-0.5)*0.15,
      a: Math.random()*0.6+0.2,
    }));
  }
  resize(); window.addEventListener('resize', resize);
  function tick() {
    ctx.clearRect(0,0,w,h);
    for (const d of dots) {
      d.x+=d.vx; d.y+=d.vy;
      if(d.x<0||d.x>w) d.vx*=-1; if(d.y<0||d.y>h) d.vy*=-1;
      ctx.beginPath(); ctx.arc(d.x,d.y,d.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(79,134,255,${d.a*opacity})`;
      ctx.shadowColor='#2060F6'; ctx.shadowBlur=8; ctx.fill();
    }
    raf=requestAnimationFrame(tick);
  }
  tick();
})();
</script>
