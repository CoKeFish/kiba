---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const DASHBOARD_URL = import.meta.env.PUBLIC_DASHBOARD_URL || "https://dashboard.kiba.rodion.com.co";
---

<section style="position: relative; overflow: hidden; background: #FFFFFF;">
  <div style="
    position: relative; z-index: 2;
    max-width: 1140px; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
  " class="hero-grid">

    <!-- Left: copy -->
    <div style="padding: 56px 0;">
      <h1 class="hero-h1">
        <span class="hero-h1-line">{t("hero.h1.line1")}</span>
        <span class="hero-h1-line">{t("hero.h1.line2pre")}<em class="hero-stamp">{t("hero.h1.line2em")}</em></span>
        <span class="hero-h1-line"><span class="line2 hero-bounce">{t("hero.h1.line3")}</span></span>
      </h1>

      <p class="hero-sub hero-blur-in">
        {t("hero.sub")}
      </p>

      <div class="hero-ctas">
        <a href="#agents" class="btn-hero btn-hero-p hero-cta-in hero-cta-d1">{t("hero.cta.explore")}</a>
        <a href="#how-it-works" class="btn-hero btn-hero-o hero-cta-in hero-cta-d2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M10 8l6 4-6 4V8z" fill="currentColor"/></svg>
          {t("hero.cta.how")}
        </a>
      </div>
    </div>

    <!-- Right: agent friends (composite) -->
    <div class="hero-art hero-art-in">
      <img
        src="/agents/friends.png"
        alt={t("hero.art.alt")}
        class="hero-friends-img"
        width="715"
        height="516"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>

<style>
  .hero-h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(38px, 4.6vw, 58px);
    line-height: .98;
    letter-spacing: -0.045em;
    color: var(--fg-1);
    margin-bottom: 20px;
  }
  .hero-h1-line {
    display: block;
    opacity: 0;
    transform: translateY(26px);
    animation: hero-title-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-h1-line:nth-child(1) { animation-delay: 0.08s; }
  .hero-h1-line:nth-child(2) { animation-delay: 0.2s; }
  .hero-h1-line:nth-child(3) { animation-delay: 0.38s; }
  @keyframes hero-title-in {
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-stamp {
    display: inline-block;
    opacity: 0;
    transform: scale(0.5) rotate(-8deg);
    animation: hero-stamp-in 0.55s cubic-bezier(0.34, 1.65, 0.64, 1) forwards;
    animation-delay: 0.42s;
  }
  @keyframes hero-stamp-in {
    to { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  .hero-bounce {
    opacity: 0;
    animation: hero-bounce-in 0.65s cubic-bezier(0.34, 1.7, 0.64, 1) forwards;
    animation-delay: 0.52s;
  }
  @keyframes hero-bounce-in {
    0% { opacity: 0; transform: scale(0.6) translateY(12px); }
    70% { opacity: 1; transform: scale(1.06) translateY(-3px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  .hero-h1 em { font-style: normal; color: var(--accent); }
  .hero-h1 .line2 {
    display: inline-block;
    background: var(--c-yellow);
    padding: 0 10px 3px;
    border-radius: 8px;
    color: var(--fg-1);
    margin-top: 3px;
  }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: 15px; color: var(--fg-2); line-height: 1.6;
    max-width: 400px; margin-bottom: 28px;
  }
  .hero-blur-in {
    opacity: 0;
    filter: blur(10px);
    transform: translateY(14px);
    animation: hero-blur-in 0.7s ease forwards;
    animation-delay: 0.72s;
  }
  @keyframes hero-blur-in {
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }

  .hero-cta-in {
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    animation: hero-cta-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-cta-d1 { animation-delay: 0.88s; }
  .hero-cta-d2 { animation-delay: 0.98s; }
  @keyframes hero-cta-in {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn-hero {
    font-family: var(--font-sans); font-weight: 700; font-size: 14px;
    padding: 12px 24px; border-radius: 999px; border: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
    transition: all var(--dur-base) var(--ease-out);
  }
  .btn-hero-p { background: var(--accent); color: #fff; box-shadow: var(--glow-md); }
  .btn-hero-p:hover { background: var(--accent-pressed); transform: translateY(-2px); box-shadow: var(--glow-lg); }
  .btn-hero-o { background: #fff; color: var(--fg-1); border: 1.5px solid var(--border-strong); }
  .btn-hero-o:hover { border-color: var(--fg-1); transform: translateY(-2px); }

  .hero-art {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 8px 0;
    background: #FFFFFF;
  }
  .hero-art-in {
    opacity: 0;
    transform: translateX(40px) rotate(4deg) scale(0.94);
    animation: hero-art-in 0.85s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.35s;
  }
  @keyframes hero-art-in {
    to { opacity: 1; transform: translateX(0) rotate(0deg) scale(1); }
  }
  .hero-friends-img {
    display: block;
    width: min(100%, 560px);
    height: auto;
    object-fit: contain;
    animation: hero-friends-float 3.5s ease-in-out infinite;
    animation-delay: 1.1s;
  }
  @keyframes hero-friends-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr !important; gap: 8px !important; }
    .hero-friends-img { width: min(100%, 420px); margin: 0 auto; }
    .hero-h1 { font-size: clamp(36px, 10vw, 52px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-h1-line,
    .hero-stamp,
    .hero-bounce,
    .hero-blur-in,
    .hero-cta-in,
    .hero-art-in {
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
      animation: none !important;
    }
    .hero-friends-img { animation: none !important; }
  }
</style>
