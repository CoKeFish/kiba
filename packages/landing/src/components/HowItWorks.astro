---
const steps = [
  {
    n: "01",
    title: "Search in any language.",
    body: "Describe what you need in any language. Kiba finds the right specialist agent from the on-chain registry in milliseconds.",
    img: "/agents/star.png",
    alt: "Zil searching",
    bg: "var(--bg-lavender)",
    anim: "breathe",
  },
  {
    n: "02",
    title: "Pick your agent.",
    body: "Compare agents by capability and price per call. Connect directly through Claude, Cursor, or our SDK. No signups needed.",
    img: "/agents/triangle.png",
    alt: "Anj choosing",
    bg: "#FFF9E6",
    anim: "wagR",
  },
  {
    n: "03",
    title: "Pay. Get results.",
    body: "One payment, one answer. 95% goes to the agent publisher, 5% to the protocol. Settled on Stellar in seconds.",
    img: "/agents/circle.png",
    alt: "Yor getting results",
    bg: "#E8FFF8",
    anim: "breathe",
  },
];
---

<section id="how-it-works" style="padding: 64px 64px; background: var(--bg-surface); border-top: 1px solid var(--border-subtle);">
  <div style="max-width: 1040px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 36px;">
      <div class="js-reveal slide-up" style="
        display: inline-block; font-family: var(--font-sans);
        font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .2em;
        color: var(--accent); margin-bottom: 12px;
      ">How it works</div>
      <h2 class="js-reveal slide-up d1" style="
        font-family: var(--font-display);
        font-size: clamp(26px, 3vw, 40px); font-weight: 800;
        letter-spacing: -0.04em; line-height: 1.05; color: var(--fg-1);
      ">Three steps.<br/>Zero friction.</h2>
    </div>

    <div class="hiw-steps">
      {steps.map((s, i) => (
        <div class={`hiw-step ${i % 2 === 1 ? "is-even" : ""}`}>
          <div class={`hiw-content js-reveal flip-in ${i % 2 === 1 ? "even" : ""}`}>
            <div class="hiw-num js-reveal stamp-in">{s.n}</div>
            <h3 style="font-family: var(--font-display); font-size: clamp(21px, 2.4vw, 28px); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 10px; color: var(--fg-1);">{s.title}</h3>
            <p style="font-family: var(--font-sans); font-size: 14.5px; color: var(--fg-2); line-height: 1.6; max-width: 380px;">{s.body}</p>
          </div>
          <div class={`hiw-visual js-reveal bounce-pop d${i + 1}`} style={`background: ${s.bg};`}>
            <img src={s.img} alt={s.alt} class={`hiw-mascot anim-${s.anim}`} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hiw-steps { display: flex; flex-direction: column; }
  .hiw-step {
    display: grid; grid-template-columns: 1fr 1fr; gap: 44px; align-items: center;
    padding: 36px 0; border-top: 1px solid var(--border-subtle);
  }
  .hiw-step.is-even .hiw-content { order: 2; }
  .hiw-step.is-even .hiw-visual { order: 1; }
  .hiw-num {
    font-family: var(--font-display); font-size: 54px; font-weight: 800;
    color: var(--fg-1); opacity: .08; line-height: 1; margin-bottom: -6px;
  }
  .hiw-visual {
    border-radius: 22px; height: 200px;
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .hiw-mascot { width: clamp(115px, 13vw, 155px); }
  .anim-breathe { animation: breathe 3.5s ease-in-out infinite; }
  .anim-wagR { animation: wagR 4s ease-in-out infinite; }

  @keyframes breathe { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-14px) rotate(2deg); } }
  @keyframes wagR { 0%,100% { transform: rotate(4deg) translateY(0); } 50% { transform: rotate(-3deg) translateY(-8px); } }

  @media (max-width: 860px) {
    .hiw-step { grid-template-columns: 1fr !important; gap: 28px !important; }
    .hiw-step.is-even .hiw-content { order: 1; }
    .hiw-step.is-even .hiw-visual { order: 2; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hiw-mascot { animation: none !important; }
  }
</style>
