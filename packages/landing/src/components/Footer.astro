  },
  {
    label: "GitHub",
    href: "https://github.com/CoKeFish/kiba",
    icon: `<svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.595 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
];
---

<footer style="
  padding: 56px 64px 32px;
  background: var(--bg-surface);
  border-top: 1px solid var(--border-subtle);
">
  <div style="
    max-width: 1240px; margin: 0 auto;
    display: flex; justify-content: space-between; gap: 48px; flex-wrap: wrap;
    margin-bottom: 40px;
  ">
    <!-- Brand -->
    <div style="min-width: 200px;">
      <div style="margin-bottom: 14px;">
        <span style="font-family: var(--font-display); font-size: 24px; font-weight: 800; color: var(--fg-1); letter-spacing: -0.04em;">Kiba<span style="color: var(--accent);">.</span></span>
      </div>
      <p style="
        font-family: var(--font-sans); font-size: 13.5px; color: var(--fg-3);
        line-height: 1.55; max-width: 240px;
      ">{t("footer.tagline")}</p>
    </div>

    <!-- Link columns -->
    <div style="
      display: grid; grid-template-columns: repeat(4, auto); gap: 56px;
    " class="footer-cols">
      {cols.map((col) => (
        <div style="display: flex; flex-direction: column; gap: 11px;">
          <div style="
            font-family: var(--font-display); font-size: 12px; font-weight: 700;
            color: var(--fg-1); margin-bottom: 4px;
          ">{col.heading}</div>
          {col.links.map((link) => (
            <a href={link.href} class="footer-link" style="
              font-family: var(--font-sans); font-size: 13.5px; font-weight: 500;
              color: var(--fg-2); text-decoration: none;
              transition: color var(--dur-fast) var(--ease-out);
            ">{link.label}</a>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="
    max-width: 1240px; margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid var(--border-subtle);
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 16px;
  ">
    <div style="display: flex; gap: 8px; align-items: center;">
      {socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class="footer-social" style="
          display: inline-flex; align-items: center; justify-content: center;
          width: 36px; height: 36px; border-radius: 999px;
          color: var(--fg-2); background: var(--bg-inset);
          transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
        "><Fragment set:html={s.icon} /></a>
      ))}
    </div>
    <span style="font-family: var(--font-sans); font-size: 13px; color: var(--fg-3);">
      {t("footer.copyright")}
    </span>
  </div>
</footer>

<style>
  .footer-link:hover { color: var(--accent) !important; }
  .footer-social:hover { color: #fff !important; background: var(--accent) !important; }

  @media (max-width: 768px) {
    .footer-cols { grid-template-columns: repeat(2, auto) !important; gap: 32px !important; }
  }
</style>
