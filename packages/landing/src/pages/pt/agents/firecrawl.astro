---
import Base from "../../../layouts/Base.astro";
import FirecrawlBody from "../../../components/pages/FirecrawlBody.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Base lang={lang} title={t("meta.firecrawl.title")} description={t("meta.firecrawl.desc")}>
  <FirecrawlBody />
</Base>
