---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import CodeTabs from "../components/CodeTabs.tsx";
import AgentsCatalog from "../components/AgentsCatalog.tsx";
import Pricing from "../components/Pricing.astro";
import Footer from "../components/Footer.astro";

const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL || "https://backend-production-fb67.up.railway.app";
---

<Base>
  <Hero />
  <HowItWorks />

  <!-- Integration channels section -->
  <section id="connect" style="
    border-top: 1px solid var(--border-subtle);
    padding: 120px 64px;
    background: var(--bg-canvas);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="eyebrow" style="margin-bottom: 16px; text-align: center;">Four integration channels</div>
      <h2 style="
        font-family: var(--font-display);
        font-size: clamp(32px, 3.5vw, 44px);
        font-weight: 600;
        color: var(--fg-1);
        letter-spacing: -0.02em;
        text-align: center;
        margin-bottom: 12px;
      ">Same agents. Different ergonomics.</h2>
      <p style="
        font-family: var(--font-sans);
        font-size: 16px;
        color: var(--fg-2);
        text-align: center;
        margin-bottom: 48px;
        max-width: 680px;
        margin-left: auto;
        margin-right: auto;
      ">Native SDK for crypto builders, REST API for backends, MCP for Claude and Cursor, and a one-click Windows installer for everyone else. Zero terminal needed.</p>
      <CodeTabs client:load />
    </div>
  </section>

  <!-- Agent search section -->
  <section id="agents" style="
    border-top: 1px solid var(--border-subtle);
    padding: 120px 64px;
    background: var(--bg-surface);
  ">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="eyebrow" style="margin-bottom: 16px; text-align: center;">Marketplace · On-chain</div>
      <h2 style="
        font-family: var(--font-display);
        font-size: clamp(32px, 3.5vw, 44px);
        font-weight: 600;
        color: var(--fg-1);
        letter-spacing: -0.02em;
        text-align: center;
        margin-bottom: 12px;
      ">Find the right agent — in any language.</h2>
      <p style="
        font-family: var(--font-sans);
        font-size: 16px;
        color: var(--fg-2);
        text-align: center;
        margin-bottom: 48px;
        max-width: 640px;
        margin-left: auto;
        margin-right: auto;
      ">
        Hybrid search over the on-chain registry: BM25 keyword + cross-lingual semantic embeddings.
        Search in any language, find agents in English. <span style="font-family: var(--font-mono); font-size: 12px; color: var(--fg-3);">(MiniLM-L6-v2, ~3ms/query)</span>
      </p>
      <script is:inline define:vars={{ BACKEND_URL }}>
        window.__BACKEND_URL__ = BACKEND_URL;
      </script>
      <AgentsCatalog client:visible />
    </div>
  </section>

  <!-- CTA section -->
  <section style="
    position: relative;
    overflow: hidden;
    padding: 120px 64px;
    text-align: center;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--blue-500) 14%, transparent), transparent 60%), var(--bg-canvas);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  ">
    <canvas id="cta-particles" style="
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      mix-blend-mode: screen;
    "></canvas>
    <div style="
      position: relative; z-index: 2;
      max-width: 720px; margin: 0 auto;
      display: flex; flex-direction: column; align-items: center; gap: 24px;
    ">
      <img src="/logomark.png" alt="" style="
        width: 96px; height: 96px; object-fit: contain;
        filter: drop-shadow(0 0 40px color-mix(in srgb, var(--blue-500) 60%, transparent));
      " />
      <h2 style="
        font-family: var(--font-display);
        font-size: clamp(32px, 4vw, 48px);
        font-weight: 600;
        color: var(--fg-1);
        letter-spacing: -0.025em;
        line-height: 1.1;
      ">
        Your next team doesn't <span style="color: var(--accent);">hire</span>. It <span style="color: var(--accent);">deploys</span>.
      </h2>
      <p style="
        font-family: var(--font-sans);
        font-size: 18px;
        color: var(--fg-2);
        max-width: 560px;
        line-height: 1.55;
      ">Create a free account and connect your first agent in under five minutes.</p>
      <div style="display: flex; gap: 14px; margin-top: 8px; flex-wrap: wrap; justify-content: center;">
        <a
          href="https://agent-bazaar-dashboard.vercel.app/signup"
          style="
            font-family: var(--font-sans);
            font-size: 15px;
            font-weight: 600;
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 14px 28px;
            border-radius: 999px;
            text-decoration: none;
            box-shadow: 0 0 30px color-mix(in srgb, var(--accent) 45%, transparent);
          "
        >Get started free</a>
        <a
          href="https://github.com/CoKeFish/agent-bazaar"
          target="_blank"
          rel="noopener"
          style="
            font-family: var(--font-sans);
            font-size: 15px;
            font-weight: 600;
            background: transparent;
            color: var(--fg-1);
            border: 1px solid var(--border-strong);
            padding: 14px 24px;
            border-radius: 999px;
            text-decoration: none;
          "
        >View on GitHub</a>
      </div>
    </div>
  </section>

  <Pricing />
  <Footer />
</Base>

<script is:inline>
(function () {
  var c = document.getElementById('cta-particles');
  if (!c) return;
  var ctx = c.getContext('2d');
  var raf, w, h, dots;
  var density = 60;
  var opacity = 0.4;
  function resize() {
    var dpr = window.devicePixelRatio || 1;
    c.width = c.offsetWidth * dpr;
    c.height = c.offsetHeight * dpr;
    w = c.width; h = c.height;
    dots = Array.from({ length: density }, function() {
      return { x: Math.random()*w, y: Math.random()*h, r: Math.random()*1.6+0.4,
        vx: (Math.random()-0.5)*0.12, vy: (Math.random()-0.5)*0.12, a: Math.random()*0.6+0.2 };
    });
  }
  resize();
  window.addEventListener('resize', resize);
  function tick() {
    ctx.clearRect(0, 0, w, h);
    for (var i = 0; i < dots.length; i++) {
      var d = dots[i];
      d.x += d.vx; d.y += d.vy;
      if (d.x < 0 || d.x > w) d.vx *= -1;
      if (d.y < 0 || d.y > h) d.vy *= -1;
      ctx.beginPath();
      ctx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(79,134,255,' + (d.a * opacity) + ')';
      ctx.shadowColor = '#2060F6';
      ctx.shadowBlur = 8;
      ctx.fill();
    }
    raf = requestAnimationFrame(tick);
  }
  tick();
})();
</script>
