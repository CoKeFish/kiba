---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import AgentsCatalog from "../components/AgentsCatalog.tsx";
import FeaturedAgents from "../components/FeaturedAgents.astro";
import Pricing from "../components/Pricing.astro";
import Footer from "../components/Footer.astro";

const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL || "https://kiba-data.rodion.com.co";
const DASHBOARD_URL = import.meta.env.PUBLIC_DASHBOARD_URL || "https://dashboard.kiba.rodion.com.co";
// Instalador de un clic (Windows) — kiba MCP en Claude Desktop / Cursor / Claude Code.
const INSTALLER_URL = "https://github.com/CoKeFish/kiba/releases/latest/download/Kiba-Installer-x64-setup.exe";

const featurePills = [
  "Hybrid search",
  "Pay per call",
  "MCP ready",
  "On-chain settlement",
  "No API keys",
];
---

<Base>
  <Hero />

  <!-- Feature pills row -->
  <div style="
    display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
    padding: 28px 64px; background: var(--bg-surface);
    border-top: 1px solid var(--border-subtle);
  ">
    {featurePills.map((label, i) => (
      <div class={`feat-pill js-reveal hover-wiggle ${i % 2 === 0 ? "wiggle-left" : "wiggle-right"} d${i + 1}`}>
        {label}
      </div>
    ))}
  </div>

  <!-- Search + agent catalog -->
  <section id="agents" style="padding: 60px 64px; background: var(--bg-canvas); border-top: 1px solid var(--border-subtle);">
    <div style="max-width: 1140px; margin: 0 auto;">
      <h2 class="js-reveal slide-up" style="
        font-family: var(--font-display);
        font-size: clamp(26px, 3vw, 40px);
        font-weight: 800; letter-spacing: -0.04em; line-height: 1.05;
        color: var(--fg-1); margin-bottom: 8px;
      ">Find the <span style="color: var(--accent);">perfect</span><br/>agent for your task.</h2>
      <p class="js-reveal slide-up d1" style="font-family: var(--font-sans); font-size: 15px; color: var(--fg-3); margin-bottom: 28px;">
        Search in any language. Results in seconds.
      </p>

      <script is:inline define:vars={{ BACKEND_URL }}>
        window.__BACKEND_URL__ = BACKEND_URL;
      </script>
      <AgentsCatalog client:visible />

      <div style="text-align: center; margin-top: 24px;">
        <a href={`${DASHBOARD_URL}/agents`} style="
          font-family: var(--font-sans); font-size: 14px; font-weight: 700;
          color: var(--accent); text-decoration: none;
        ">View all agents →</a>
      </div>
    </div>
  </section>

  <HowItWorks />

  <FeaturedAgents />

  <Pricing />

  <!-- CTA band (dark) -->
  <section style="padding: 32px 52px 64px; background: var(--bg-canvas);">
    <div class="js-reveal bounce-pop" style="
      position: relative; overflow: hidden;
      max-width: 1140px; margin: 0 auto;
      border-radius: 26px;
      background: var(--bg-ink);
      padding: 52px 48px;
      display: flex; align-items: center; justify-content: space-between;
      gap: 40px; flex-wrap: wrap;
    ">
      <div class="cta-glow cta-glow-pulse" style="width: 400px; height: 400px; background: var(--accent); top: -100px; left: -80px;"></div>
      <div class="cta-glow cta-glow-pulse" style="width: 300px; height: 300px; background: var(--c-teal); bottom: -80px; right: 100px;"></div>

      <div style="position: relative; z-index: 2; max-width: 480px;">
        <h2 style="
          font-family: var(--font-display);
          font-size: clamp(24px, 2.8vw, 34px); font-weight: 800;
          color: #fff; letter-spacing: -0.04em; line-height: 1.05; margin-bottom: 10px;
        ">Your next team doesn't hire. It <span style="color: var(--c-yellow);">deploys.</span></h2>
        <p style="font-family: var(--font-sans); font-size: 14px; color: rgba(255,255,255,.55); line-height: 1.6;">
          Create a free account and connect your first agent in under five minutes.
        </p>
      </div>
      <div style="position: relative; z-index: 2; display: flex; gap: 12px; flex-wrap: wrap;">
        <a
          href={`${DASHBOARD_URL}/signup`}
          class="btn-cta"
          style="
            font-family: var(--font-sans); font-size: 15px; font-weight: 700;
            background: #fff; color: var(--fg-1);
            padding: 15px 34px; border-radius: 999px; text-decoration: none;
            white-space: nowrap;
            transition: transform var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
          "
        >Start exploring →</a>
        <a
          href={INSTALLER_URL}
          title="Windows one-click installer (.exe)"
          style="
            display: inline-flex; align-items: center; gap: 8px;
            font-family: var(--font-sans); font-size: 15px; font-weight: 700;
            background: rgba(255,255,255,.12); color: #fff;
            border: 1.5px solid rgba(255,255,255,.45);
            padding: 15px 26px; border-radius: 999px; text-decoration: none;
            white-space: nowrap;
            transition: background var(--dur-fast) var(--ease-out);
          "
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
          Download
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .feat-pill {
    display: flex; align-items: center; gap: 12px;
    padding: 13px 24px; border-radius: 999px;
    border: 1px solid var(--border-default); background: #fff;
    font-family: var(--font-sans); font-size: 14px; font-weight: 600; color: var(--fg-1);
    transition: all var(--dur-base) var(--ease-out); cursor: default;
  }
  .feat-pill:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

  .cta-glow { position: absolute; border-radius: 50%; filter: blur(80px); opacity: .35; pointer-events: none; }
  .btn-cta:hover { background: var(--c-yellow); transform: translateY(-2px); }
</style>
