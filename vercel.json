{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build --workspace=@kiba/dashboard",
  "outputDirectory": "packages/dashboard/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://kiba-api.rodion.com.co/:path*" },
    { "source": "/backend/:path*", "destination": "https://kiba-data.rodion.com.co/:path*" },
    { "source": "/((?!assets|.*\\.).*)", "destination": "/index.html" }
  ]
}
