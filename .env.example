# ===========================================
# Kiba — variables de entorno
# Copiar a .env y rellenar
# ===========================================

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# LLM API (uno de los dos, recomendado Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Backend
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:6001
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Programa on-chain (se llena después de deploy con el Program ID de kiba)
PROGRAM_ID=

# Wallet del operador (path al keypair, dentro del container)
OPERATOR_KEYPAIR=/root/.config/solana/id.json

# Cadena activa para el stack: 'stellar' (esta versión) o 'solana'.
CHAIN=stellar

# Stellar / Soroban (usado cuando CHAIN=stellar)
STELLAR_CONTRACT_ID=CDYLMRS2UTBHNTWS67NC2OPQIH2HXGS36WZYC4JUMLKZWT7XXVUUX7XF
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SERVICES=yield-hunter,risk-auditor,translator-pro,price-oracle,code-reviewer
XLM_USD_RATE=0.12
