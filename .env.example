# ===========================================
# Kiba — variables de entorno
# Copiar a .env y rellenar
# ===========================================

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# LLM API (uno de los dos, recomendado Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Backend
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:6001
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Programa on-chain (se llena después de deploy con el Program ID de kiba)
PROGRAM_ID=

# Wallet del operador (path al keypair, dentro del container)
OPERATOR_KEYPAIR=/root/.config/solana/id.json

# Cadena activa para el stack: 'stellar' (esta versión) o 'solana'.
CHAIN=stellar

# Stellar / Soroban (usado cuando CHAIN=stellar)
STELLAR_CONTRACT_ID=CDYLMRS2UTBHNTWS67NC2OPQIH2HXGS36WZYC4JUMLKZWT7XXVUUX7XF
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SERVICES=yield-hunter,risk-auditor,translator-pro,price-oracle,code-reviewer
XLM_USD_RATE=0.12

# ===========================================
# Gateway — secretos y config (deploy real)
# ===========================================
# Secreto de firma de sesiones JWT. Genera con: openssl rand -base64 48
# Si se deja vacío, el gateway genera uno ALEATORIO efímero (sesiones no persisten entre reinicios).
JWT_SECRET=
# Hostnames permitidos para el redirect_uri de OAuth (CSV).
ALLOWED_REDIRECT_ORIGINS=localhost,127.0.0.1,[::1]
# Master/treasury wallet del gateway (custodia). Secret key (JSON array) o path al keypair.
MASTER_WALLET_SECRET=
MASTER_KEYPAIR_PATH=/app/data/master-wallet.json
# URL pública del gateway (callbacks/links OAuth)
PUBLIC_URL=http://localhost:8000
SOL_USD_RATE=150

# Discovery (backend)
SEMANTIC_SEARCH=true

# Frontends (Astro hornea PUBLIC_* en build time)
PUBLIC_BACKEND_URL=http://localhost:4000
PUBLIC_GATEWAY_URL=http://localhost:8000
PUBLIC_DASHBOARD_URL=http://localhost:3020
