# ===========================================
# Kiba — variables de entorno
# Copiar a .env y rellenar
# ===========================================

# LLM API (uno de los dos, recomendado Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Backend
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:6001

# Cadena activa del stack: Stellar/Soroban.
CHAIN=stellar

# Stellar / Soroban (usado cuando CHAIN=stellar)
STELLAR_CONTRACT_ID=CDYLMRS2UTBHNTWS67NC2OPQIH2HXGS36WZYC4JUMLKZWT7XXVUUX7XF
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SERVICES=yield-hunter,risk-auditor,translator-pro,price-oracle,code-reviewer,firecrawl
# Activo de liquidación = USDC (vía Trustless Work). Tasa USD ≈ 1.0.
USDC_USD_RATE=1.0

# Trustless Work — escrow del pago x402 (https://www.trustlesswork.com)
# El registro de agentes sigue en el contrato Soroban (STELLAR_CONTRACT_ID); el
# escrow (open/fund/release/refund) se liquida vía la API de Trustless Work.
# La API key se genera en el BackOffice dApp de TW. Sin ella, el escrow NO liquida.
TRUSTLESS_WORK_API_KEY=
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com
# Dirección de la plataforma (recibe el platformFee + resuelve disputas). = treasury.
TRUSTLESS_WORK_PLATFORM_ADDRESS=
# Comisión de la plataforma en % (5 = 5%, equivalente a los 500 bps del contrato).
TRUSTLESS_WORK_PLATFORM_FEE=5
# Trustline (token) que mueve el escrow. Testnet USDC = Circle (issuer G..., centre.io).
TRUSTLESS_WORK_TRUSTLINE_ADDRESS=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
TRUSTLESS_WORK_TRUSTLINE_SYMBOL=USDC

# Firecrawl — agente REAL de web scraping (puerto 5006).
# Carga contenido dinámico (precios de productos, páginas con render JS, etc).
# Crea una API key gratis en https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxx

# ===========================================
# Pagos fiat → créditos (Kibs)
# ===========================================
# Métodos: se ofrecen TODOS los configurados a la vez (bre-b-sandbox siempre +
# wompi/stripe/paypal si hay llaves). PAYMENT_PROVIDER solo marca cuál va de primero.
PAYMENT_PROVIDER=bre-b-sandbox
# Tasa COP→USD para convertir recargas locales (solo display/cálculo de créditos).
COP_USD_RATE=4000
# Wompi (https://comercios.wompi.co → llaves de integración). Para sandbox usa las
# llaves de prueba (pub_test_/prv_test_) y deja WOMPI_API_URL en sandbox.
# Requeridas si PAYMENT_PROVIDER=wompi; si faltan, cae a bre-b-sandbox.
WOMPI_PUBLIC_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_API_URL=https://sandbox.wompi.co/v1
# Para producción: WOMPI_API_URL=https://production.wompi.co/v1 + llaves pub_prod_/prv_prod_

# Stripe (tarjeta internacional). Para el demo: PAYMENT_PROVIDER=stripe + la secret key
# de TEST (sk_test_...) — se obtienen al instante en dashboard.stripe.com SIN KYC.
# El webhook secret (whsec_...) es opcional en local (el flujo verify-por-redirect ya
# acredita); requerido en prod para que el webhook firme. Cobra en USD (COP→USD→Kibs).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal (cuenta/tarjeta internacional). Credenciales de SANDBOX al instante en
# developer.paypal.com (crea una app) — client id + secret, sin KYC. Cobra en USD.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
# Producción: PAYPAL_API_URL=https://api-m.paypal.com + credenciales live.

# USDC en Stellar (depósito cripto, estilo AstroPay). Aparece como método solo si
# hay dirección receptora + issuer. Dirección: una cuenta Stellar TUYA con trustline
# USDC (testnet). Issuer/Horizon se reusan de la config Stellar/Trustless Work de arriba.
# Si STELLAR_DEPOSIT_ADDRESS queda vacía, cae a TRUSTLESS_WORK_PLATFORM_ADDRESS.
STELLAR_DEPOSIT_ADDRESS=

# ===========================================
# Gateway — secretos y config (deploy real)
# ===========================================
# Secreto de firma de sesiones JWT. Genera con: openssl rand -base64 48
# Si se deja vacío, el gateway genera uno ALEATORIO efímero (sesiones no persisten entre reinicios).
JWT_SECRET=
# Hostnames permitidos para el redirect_uri de OAuth (CSV).
ALLOWED_REDIRECT_ORIGINS=localhost,127.0.0.1,[::1]
# Master/treasury wallet del gateway (custodia). Secret key (JSON array) o path al keypair.
MASTER_WALLET_SECRET=
MASTER_KEYPAIR_PATH=/app/data/master-wallet.json
# URL pública del gateway (callbacks/links OAuth)
PUBLIC_URL=http://localhost:8000

# Discovery (backend)
SEMANTIC_SEARCH=true

# Frontends (Astro hornea PUBLIC_* en build time)
PUBLIC_BACKEND_URL=http://localhost:4000
PUBLIC_GATEWAY_URL=http://localhost:8000
PUBLIC_DASHBOARD_URL=http://localhost:5173

# ===========================================
# Pagos off-chain + liquidación por lotes
# ===========================================
# Secreto compartido gateway↔agentes para la vía de confianza (header X-Platform-Auth): el
# gateway llama al agente SIN escrow per-call (el pago se concilia off-chain y se liquida por
# lotes). DEBE estar en el gateway Y en cada proceso de agente con el MISMO valor; si falta o
# no coincide, el agente exige el flujo x402 y la llamada de crédito falla (fail-closed).
# Genera con: openssl rand -base64 48
PLATFORM_CALL_SECRET=
# Liquidación on-chain (vía Trustless Work) por lotes. Monto mínimo para liquidar, en unidades
# base (stroops): 10000000 = 1 USDC. Por debajo no se liquida (evita polvo).
SETTLEMENT_MIN_PAYOUT=10000000
# Si se setea (ms), el gateway corre un job que liquida a todos los agentes con acumulado >=
# mínimo. Vacío = solo liquidación bajo demanda (POST /v1/publisher/settle).
SETTLEMENT_INTERVAL_MS=

# ===========================================
# Privy — wallets de usuario no-custodiales (https://privy.io)
# ===========================================
# La clave ed25519 vive en el TEE de Privy; el gateway guarda solo un wallet_id y firma vía
# raw_sign. Con estas seteadas, las wallets de usuario se provisionan en Privy (server wallets
# app-owned, firmables con el app-secret). Sin ellas → keypair custodial local (legacy).
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_API_URL=https://api.privy.io/v1
