# ===========================================
# Kiba — variables de entorno
# Copiar a .env y rellenar
# ===========================================

# LLM API (uno de los dos, recomendado Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Backend
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:6001

# Cadena activa del stack: Stellar/Soroban.
CHAIN=stellar

# Stellar / Soroban (usado cuando CHAIN=stellar)
STELLAR_CONTRACT_ID=CDYLMRS2UTBHNTWS67NC2OPQIH2HXGS36WZYC4JUMLKZWT7XXVUUX7XF
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SERVICES=yield-hunter,risk-auditor,translator-pro,price-oracle,code-reviewer
# Activo de liquidación = USDC (vía Trustless Work). Tasa USD ≈ 1.0.
USDC_USD_RATE=1.0

# Trustless Work — escrow del pago x402 (https://www.trustlesswork.com)
# El registro de agentes sigue en el contrato Soroban (STELLAR_CONTRACT_ID); el
# escrow (open/fund/release/refund) se liquida vía la API de Trustless Work.
# La API key se genera en el BackOffice dApp de TW. Sin ella, el escrow NO liquida.
TRUSTLESS_WORK_API_KEY=
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com
# Dirección de la plataforma (recibe el platformFee + resuelve disputas). = treasury.
TRUSTLESS_WORK_PLATFORM_ADDRESS=
# Comisión de la plataforma en % (5 = 5%, equivalente a los 500 bps del contrato).
TRUSTLESS_WORK_PLATFORM_FEE=5
# Trustline (token) que mueve el escrow. Testnet USDC = Circle (issuer G..., centre.io).
TRUSTLESS_WORK_TRUSTLINE_ADDRESS=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
TRUSTLESS_WORK_TRUSTLINE_SYMBOL=USDC

# ===========================================
# Gateway — secretos y config (deploy real)
# ===========================================
# Secreto de firma de sesiones JWT. Genera con: openssl rand -base64 48
# Si se deja vacío, el gateway genera uno ALEATORIO efímero (sesiones no persisten entre reinicios).
JWT_SECRET=
# Hostnames permitidos para el redirect_uri de OAuth (CSV).
ALLOWED_REDIRECT_ORIGINS=localhost,127.0.0.1,[::1]
# Master/treasury wallet del gateway (custodia). Secret key (JSON array) o path al keypair.
MASTER_WALLET_SECRET=
MASTER_KEYPAIR_PATH=/app/data/master-wallet.json
# URL pública del gateway (callbacks/links OAuth)
PUBLIC_URL=http://localhost:8000

# Discovery (backend)
SEMANTIC_SEARCH=true

# Frontends (Astro hornea PUBLIC_* en build time)
PUBLIC_BACKEND_URL=http://localhost:4000
PUBLIC_GATEWAY_URL=http://localhost:8000
PUBLIC_DASHBOARD_URL=http://localhost:3020
